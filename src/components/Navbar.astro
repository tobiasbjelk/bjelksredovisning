---
const links = [
  { href: "#hem", label: "Hem" },
  { href: "#tjanster", label: "Tjänster" },
  { href: "#om-oss", label: "Om oss" },
  { href: "#kontakt", label: "Kontakt" },
];
---

<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-100">
  <div class="mx-auto max-w-6xl flex items-center justify-between px-4 py-4">
    <a href="#hem" class="text-xl font-bold text-slate-900">
      Bjelks<span class="text-brand-accent">redovisning</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex gap-8">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link relative text-slate-600 hover:text-brand-accent-dark transition-colors font-medium"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Öppna meny"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-slate-700 transition-transform" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-slate-700 transition-opacity" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-slate-700 transition-transform" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100">
    <ul class="flex flex-col px-4 py-4 gap-4">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-link block text-slate-600 hover:text-brand-accent-dark transition-colors font-medium text-lg"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0;
    height: 2px;
    background-color: var(--color-brand-accent);
    transition: width 0.25s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }
</style>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const bar1 = document.getElementById("bar1")!;
  const bar2 = document.getElementById("bar2")!;
  const bar3 = document.getElementById("bar3")!;

  toggle.addEventListener("click", () => {
    const open = menu.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!open));
    bar1.classList.toggle("rotate-45", !open);
    bar1.classList.toggle("translate-y-2", !open);
    bar2.classList.toggle("opacity-0", !open);
    bar3.classList.toggle("-rotate-45", !open);
    bar3.classList.toggle("-translate-y-2", !open);
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
      bar1.classList.remove("rotate-45", "translate-y-2");
      bar2.classList.remove("opacity-0");
      bar3.classList.remove("-rotate-45", "-translate-y-2");
    });
  });
</script>
