---
import { getCollection, render } from "astro:content";

const services = (await getCollection("tjanster")).sort(
  (a, b) => a.data.order - b.data.order,
);

const renderedServices = await Promise.all(
  services.map(async (service) => {
    const { Content } = await render(service);
    return { ...service, Content };
  }),
);
---

<section id="tjanster" class="bg-brand-light py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 text-center">
      Våra tjänster
    </h2>
    <p class="mt-4 text-slate-600 text-center max-w-2xl mx-auto text-lg">
      Vi erbjuder ett brett utbud av redovisningstjänster anpassade för småföretag.
    </p>
    <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        renderedServices.map(({ data, Content }) => (
          <div class="group flex flex-col rounded-xl bg-white p-8 shadow-sm hover:shadow-md transition-all border border-slate-100 hover:border-brand-accent/30">
            <span class="text-4xl" role="img" aria-hidden="true">
              {data.icon}
            </span>
            <h3 class="mt-4 text-xl font-semibold text-slate-900">
              {data.title}
            </h3>
            <div class="mt-4 flex-1 flex flex-col service-body">
              <Content />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-body :global(p) {
    color: var(--color-slate-600);
    line-height: 1.7;
    font-size: 0.938rem;
  }

  .service-body :global(p + p) {
    margin-top: 0.75rem;
  }

  .service-body :global(ul) {
    margin-top: auto;
    padding-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-left: 0;
    list-style: none;
  }

  .service-body :global(li) {
    color: var(--color-slate-600);
    font-size: 0.938rem;
    padding-left: 1.25rem;
    position: relative;
  }

  .service-body :global(li)::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-brand-accent);
  }
</style>
