---
import { getCollection } from "astro:content";

const siteData = await getCollection("site");
const contactData = siteData.find((entry) => entry.id === "contact");
const contact = contactData?.data.contact!;
---

<section id="kontakt" class="bg-brand-light py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 text-center">
      {contact.heading}
    </h2>
    <div class="mt-12 grid gap-8 md:grid-cols-3 max-w-4xl mx-auto">
      <!-- Phone -->
      <div class="rounded-xl bg-white p-8 text-center shadow-sm border border-slate-100">
        <span class="text-3xl" role="img" aria-hidden="true">&#x1F4DE;</span>
        <h3 class="mt-4 text-lg font-semibold text-slate-900">Telefon</h3>
        <a
          href={`tel:${contact.phone.replace(/[\s-]/g, "")}`}
          class="mt-2 block text-brand-accent-dark hover:underline"
        >
          {contact.phone}
        </a>
      </div>

      <!-- Email -->
      <div class="rounded-xl bg-white p-8 text-center shadow-sm border border-slate-100">
        <span class="text-3xl" role="img" aria-hidden="true">&#x2709;&#xFE0F;</span>
        <h3 class="mt-4 text-lg font-semibold text-slate-900">E-post</h3>
        <a
          href={`mailto:${contact.email}`}
          class="mt-2 block text-brand-accent-dark hover:underline"
        >
          {contact.email}
        </a>
      </div>

      <!-- Address -->
      <div class="rounded-xl bg-white p-8 text-center shadow-sm border border-slate-100">
        <span class="text-3xl" role="img" aria-hidden="true">&#x1F4CD;</span>
        <h3 class="mt-4 text-lg font-semibold text-slate-900">Adress</h3>
        <p class="mt-2 text-slate-600">{contact.address}</p>
      </div>
    </div>
  </div>
</section>
