---
import { getCollection } from "astro:content";

const siteData = await getCollection("site");
const contactData = siteData.find((entry) => entry.id === "contact");
const contact = contactData?.data.contact!;

const phoneSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`;

const emailSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`;

const mapPinSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`;
---

<section id="kontakt" class="bg-brand-light py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 text-center" data-animate>
      {contact.heading}
    </h2>
    <div class="mt-12 grid gap-8 md:grid-cols-3 max-w-4xl mx-auto">
      <!-- Phone -->
      <div
        class="rounded-xl bg-white p-8 text-center shadow-sm border border-slate-100 hover:shadow-md hover:-translate-y-0.5 transition-all"
        data-animate
        style="transition-delay: 0ms"
      >
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-brand-light text-brand-accent">
          <Fragment set:html={phoneSvg} />
        </div>
        <h3 class="mt-4 text-lg font-semibold text-slate-900">Telefon</h3>
        <a
          href={`tel:${contact.phone.replace(/[\s-]/g, "")}`}
          class="mt-2 block text-brand-accent-dark hover:underline"
        >
          {contact.phone}
        </a>
      </div>

      <!-- Email -->
      <div
        class="rounded-xl bg-white p-8 text-center shadow-sm border border-slate-100 hover:shadow-md hover:-translate-y-0.5 transition-all"
        data-animate
        style="transition-delay: 100ms"
      >
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-brand-light text-brand-accent">
          <Fragment set:html={emailSvg} />
        </div>
        <h3 class="mt-4 text-lg font-semibold text-slate-900">E-post</h3>
        <a
          href={`mailto:${contact.email}`}
          class="mt-2 block text-brand-accent-dark hover:underline"
        >
          {contact.email}
        </a>
      </div>

      <!-- Address -->
      <div
        class="rounded-xl bg-white p-8 text-center shadow-sm border border-slate-100 hover:shadow-md hover:-translate-y-0.5 transition-all"
        data-animate
        style="transition-delay: 200ms"
      >
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-brand-light text-brand-accent">
          <Fragment set:html={mapPinSvg} />
        </div>
        <h3 class="mt-4 text-lg font-semibold text-slate-900">Adress</h3>
        <p class="mt-2 text-slate-600">{contact.address}</p>
      </div>
    </div>
  </div>
</section>
